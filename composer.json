{
  "name": "bwtech/files_texteditor",
  "description": "Text Editor for owncloud.online, modified by BW-Tech GmbH for PHP 8.4 compatibility.",
  "homepage": "https://github.com/GrossLukas/files_texteditor",
  "license": "AGPL-3.0-only",
  "modified-by": "BW-Tech GmbH",
  "config" : {
    "platform": {
      "php": "8.4"
    },
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    }
  },
  "replace": {
    "firebase/php-jwt": "^7"
  },
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.8",
    "roave/security-advisories": "dev-latest"
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": false
    }
  },
  "support": {
    "issues": "https://github.com/GrossLukas/files_texteditor/issues",
    "source": "https://github.com/GrossLukas/files_texteditor"
  }
}
